# Local dev environment
.streamlib/
.envrc
.cargo/config.toml

plan.md

# In-flight task handoff notes (working files for cross-session pickup,
# not part of any PR). Pattern matches TASK-401.md, TASK-NNN.md, etc.
TASK-*.md

# Generated bindings — each consuming package/crate regenerates from its
# own streamlib.yaml at build time (build.rs for Rust crates; setup.py
# build hook for the Python SDK; `deno task setup` for Deno projects).
# See docs/architecture/schema-identity-and-packaging.md.
_generated_/

# Local-only operator override files (scripts + runbooks): machine-specific
# values, private deployment targets, secrets. Convention is <name>.local.<ext>
# sitting next to a committed generic <name>.<ext>. Never part of a PR.
*.local.sh
*.local.md
