# The published distribution is SOURCE ONLY — the registry stores a packaged
# artifact of the source, like cargo (excludes target/) or npm (excludes built
# dist/). `_generated_/` is a build artifact regenerated by the runtime layer
# (or locally) after the source is pulled down; it is NOT shipped. Exclude it
# and the usual build/cache cruft explicitly so a stray on-disk tree from a
# local build never leaks into the distribution.
include python/streamlib/py.typed
include streamlib.yaml streamlib.lock setup.py
prune python/streamlib/_generated_
prune python/streamlib/tests
global-exclude __pycache__ *.py[cod] *.so
