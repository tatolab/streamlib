# Rust build artifacts
/target/

# The lockfile is machine-local (it pins the local `streamlib link --engine`
# patch path / linked checkout).
Cargo.lock

# node_modules-style package folder + its lockfile — regenerated by ./setup.sh.
/streamlib_modules/
/streamlib.lock

# `streamlib link --engine` writes a machine-local override here.
/.cargo/
/.streamlib-link/

# Python / Deno build + cache artifacts
__pycache__/
*.pyc

# Model weights auto-downloaded by ultralytics at runtime
*.pt
