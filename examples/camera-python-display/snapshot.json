{
  "name": "cyberpunk-pipeline",
  "processors": [
    {
      "alias": "camera",
      "type": { "org": "tatolab", "package": "streamlib-camera", "type": "CameraProcessor", "version": "1.0.0" },
      "config": {}
    },
    {
      "alias": "avatar",
      "type": { "org": "tatolab", "package": "streamlib-python-host", "type": "PythonContinuousHostProcessor", "version": "1.0.0" },
      "config": {
        "project_path": "examples/camera-python-display/python",
        "class_name": "AvatarCharacter",
        "entry_point": "avatar_character.py"
      }
    },
    {
      "alias": "blending",
      "type": { "org": "tatolab", "package": "streamlib-blending", "type": "BlendingCompositorProcessor", "version": "1.0.0" },
      "config": {}
    },
    {
      "alias": "lower_third",
      "type": { "org": "tatolab", "package": "streamlib-python-host", "type": "PythonContinuousHostProcessor", "version": "1.0.0" },
      "config": {
        "project_path": "examples/camera-python-display/python",
        "class_name": "CyberpunkLowerThird",
        "entry_point": "cyberpunk_lower_third.py"
      }
    },
    {
      "alias": "watermark",
      "type": { "org": "tatolab", "package": "streamlib-python-host", "type": "PythonContinuousHostProcessor", "version": "1.0.0" },
      "config": {
        "project_path": "examples/camera-python-display/python",
        "class_name": "CyberpunkWatermark",
        "entry_point": "cyberpunk_watermark.py"
      }
    },
    {
      "alias": "crt_film_grain",
      "type": { "org": "tatolab", "package": "streamlib-effects", "type": "CrtFilmGrainProcessor", "version": "1.0.0" },
      "config": {}
    },
    {
      "alias": "glitch",
      "type": { "org": "tatolab", "package": "streamlib-python-host", "type": "PythonContinuousHostProcessor", "version": "1.0.0" },
      "config": {
        "project_path": "examples/camera-python-display/python",
        "class_name": "CyberpunkGlitch",
        "entry_point": "cyberpunk_glitch.py"
      }
    },
    {
      "alias": "display",
      "type": { "org": "tatolab", "package": "streamlib-display", "type": "DisplayProcessor", "version": "1.0.0" },
      "config": {
        "width": 1920,
        "height": 1080,
        "title": "Cyberpunk Pipeline (Parallel)",
        "scaling_mode": "Letterbox",
        "vsync": false,
        "drawable_count": 2
      }
    }
  ],
  "connections": [
    { "from": "camera.video", "to": "blending.video_in" },
    { "from": "camera.video", "to": "avatar.video_in" },
    { "from": "avatar.video_out", "to": "blending.pip_in" },
    { "from": "lower_third.video_out", "to": "blending.lower_third_in" },
    { "from": "watermark.video_out", "to": "blending.watermark_in" },
    { "from": "blending.video_out", "to": "crt_film_grain.video_in" },
    { "from": "crt_film_grain.video_out", "to": "glitch.video_in" },
    { "from": "glitch.video_out", "to": "display.video" }
  ]
}
