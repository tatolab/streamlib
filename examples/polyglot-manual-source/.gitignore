# Rust build artifacts
/target/

# The SDK isn't published yet, so the lockfile is machine-local.
Cargo.lock

# node_modules-style package folder + its lockfile — regenerated by ./setup.sh.
/streamlib_modules/
/streamlib.lock

# `streamlib link --engine` writes a machine-local override here.
/.cargo/
/.streamlib-link/

# Counting-sink plugin cdylib staged by the runner at startup.
/plugin/lib/

# Python / Deno build + cache artifacts
__pycache__/
*.pyc
