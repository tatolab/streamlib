# Rust build artifacts
/target/

# The lockfile is machine-local (it pins the local `streamlib link --engine`
# patch path / linked checkout).
Cargo.lock

# node_modules-style package folder + its lockfile — regenerated by ./setup.sh
# (`streamlib link` / `streamlib install`). Not committed; entries record
# machine-local absolute paths.
/streamlib_modules/
/streamlib.lock

# `streamlib link --engine` writes a machine-local [patch.crates-io] here;
# `streamlib unlink --engine` removes it. Never commit the local override.
/.cargo/
/.streamlib-link/

# Recorded media output (once the recorder is restored)
*.mp4
*.mov
